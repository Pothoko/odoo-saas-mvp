# =============================================================================
# PostgreSQL HA Cluster — Variables de entorno
#
# Copia este archivo a .env y completa los valores de RadosGW/S3.
# Las contraseñas de PostgreSQL se generan automáticamente en
# .secrets.generated la primera vez que ejecutas deploy-all.sh.
#
# Uso:
#   cp .env.example .env
#   nano .env   # completar RADOSGW_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY
#   ./deploy-all.sh
#
# NUNCA commitear .env ni .secrets.generated
# =============================================================================

# ─── RadosGW / S3 (obtener de: radosgw-admin user info --uid=pgbackrest) ───
RADOSGW_ENDPOINT=http://<rgw_host>:7480
S3_ACCESS_KEY=<access_key_from_radosgw_admin>
S3_SECRET_KEY=<secret_key_from_radosgw_admin>
S3_BUCKET=pg-backups

# ─── Nodos del clúster (no cambiar a menos que cambien las VMs) ───
NODE1_NAME=pg-node1
NODE1_SSH_IP=10.40.2.182
NODE1_INTERNAL_IP=192.168.0.127

NODE2_NAME=pg-node2
NODE2_SSH_IP=10.40.2.174
NODE2_INTERNAL_IP=192.168.0.186

NODE3_NAME=pg-node3
NODE3_SSH_IP=10.40.2.193
NODE3_INTERNAL_IP=192.168.0.226

# ─── SSH ───
SSH_KEY=/home/fisbert/.ssh/id_rsa
SSH_USER=ubuntu
