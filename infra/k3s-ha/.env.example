# =============================================================================
# infra/k3s-ha/.env.example — Variables para el despliegue K3s HA
#
# Uso:
#   cp .env.example .env
#   nano .env   # completar CEPH_CSI_KEY y K3S_TOKEN
#   ./deploy-k3s-cluster.sh
#
# ⚠️  NUNCA hacer git commit de .env — está en .gitignore
# =============================================================================

# ─── K3s Cluster ──────────────────────────────────────────────────────────────
# Token compartido entre los 3 nodos. Generar con:
#   openssl rand -hex 32
K3S_TOKEN=change_me

# VIP del API server (kube-vip ARP)
KUBE_VIP_IP=192.168.0.150

# Interfaz de red en los nodos K3s que conecta a 192.168.0.x
K3S_INTERFACE=ens3

# ─── Ceph CSI ─────────────────────────────────────────────────────────────────
CEPH_CLUSTER_ID=99efe072-cf04-11f0-adef-0cc47af94ce2
CEPH_MON_1=10.40.1.240:6789
CEPH_MON_2=10.40.1.241:6789
CEPH_RBD_POOL=k3s-rbd

# Key del usuario client.k3s-rbd-csi (permisos mínimos sobre pool k3s-rbd)
# Obtener con: ceph auth get-key client.k3s-rbd-csi
CEPH_CSI_KEY=change_me

# Key del admin para el provisioner (puede usar CEPHFS_ADMIN_KEY del cluster Ceph)
# Obtener con: ceph auth get-key client.admin
CEPH_ADMIN_KEY=change_me
