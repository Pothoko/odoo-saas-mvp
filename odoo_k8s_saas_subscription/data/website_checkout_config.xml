<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Force all eCommerce customers to create an account or log in before
        they can proceed to checkout.  This prevents orphan guest purchases
        that result in subscriptions unreachable from the customer portal.

        Values: optional | disabled | mandatory
    -->
    <record id="website.default_website" model="website">
        <field name="account_on_checkout">mandatory</field>
    </record>
</odoo>
