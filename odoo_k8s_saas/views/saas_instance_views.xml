<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Tree view -->
  <record id="view_saas_instance_tree" model="ir.ui.view">
    <field name="name">saas.instance.tree</field>
    <field name="model">saas.instance</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="tenant_id"/>
        <field name="plan"/>
        <field name="state" widget="badge"
               decoration-success="state == 'ready'"
               decoration-warning="state == 'provisioning'"
               decoration-danger="state == 'error'"
               decoration-muted="state in ('draft', 'deleted')"/>
        <field name="url" widget="url"/>
        <field name="partner_id"/>
      </list>
    </field>
  </record>

  <!-- Form view -->
  <record id="view_saas_instance_form" model="ir.ui.view">
    <field name="name">saas.instance.form</field>
    <field name="model">saas.instance</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_check_availability" type="object" string="Check Availability"
                  class="btn-secondary"
                  invisible="state not in ('draft', 'error')"/>
          <button name="action_provision" type="object" string="Provision"
                  class="btn-primary"
                  invisible="state not in ('draft', 'error')"/>
          <button name="action_check_status" type="object" string="Refresh Status"
                  invisible="state != 'provisioning'"/>
          <button name="action_delete" type="object" string="Delete Instance"
                  class="btn-danger"
                  invisible="state in ('draft', 'deleted')"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,provisioning,ready"/>
        </header>
        <sheet>
          <group>
            <group string="Identity">
              <field name="name"/>
              <field name="tenant_id"/>
              <field name="partner_id"/>
              <field name="sale_order_id" readonly="1"/>
            </group>
            <group string="Configuration">
              <field name="plan"/>
              <field name="storage_gi"/>
              <field name="url" widget="url" readonly="1"/>
              <field name="namespace" readonly="1"/>
            </group>
          </group>
          <group string="Error" invisible="not error_msg">
            <field name="error_msg" nolabel="1"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_saas_instances" model="ir.actions.act_window">
    <field name="name">SaaS Instances</field>
    <field name="res_model">saas.instance</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Menu item under Technical -->
  <menuitem id="menu_saas_root" name="SaaS" parent="base.menu_administration" sequence="99"/>
  <menuitem id="menu_saas_instances" name="Instances"
            parent="menu_saas_root"
            action="action_saas_instances" sequence="10"/>
</odoo>
