<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Run status refresh every 2 minutes -->
  <record id="ir_cron_check_instance_status" model="ir.cron">
    <field name="name">SaaS: Refresh Instance Status</field>
    <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
    <field name="state">code</field>
    <field name="code">
model.search([('state', '=', 'provisioning')]).action_check_status()
    </field>
    <field name="interval_number">2</field>
    <field name="interval_type">minutes</field>

    <field name="active">True</field>
  </record>
</odoo>
