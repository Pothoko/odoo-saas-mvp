<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Product category used to identify SaaS products.
             Assign your SaaS subscription products to this category
             (or a child of it) so that paid invoices trigger provisioning. -->
        <record id="product_category_odoo_saas" model="product.category">
            <field name="name">Odoo-SaaS</field>
        </record>

        <!-- Sequence for generating unique tenant IDs -->
        <record id="seq_saas_tenant_id" model="ir.sequence">
            <field name="name">SaaS Tenant ID</field>
            <field name="code">saas.tenant.id</field>
            <field name="prefix"></field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
