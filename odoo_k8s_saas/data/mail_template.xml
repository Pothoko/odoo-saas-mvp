<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_instance_provisioned" model="mail.template">
            <field name="name">SaaS Instance: Provisioned</field>
            <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
            <field name="email_from">{{ (user.company_id.email or user.email or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="subject">Your Odoo SaaS instance is being set up — {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="margin: 0; padding: 0;">
    <table width="600" style="margin: 20px auto; font-family: Arial, sans-serif; border-collapse: collapse;">
        <tr>
            <td style="background-color: #875A7B; padding: 20px; color: #fff; text-align: center; border-radius: 8px 8px 0 0;">
                <h1 style="margin: 0; font-size: 22px;">Your Odoo SaaS Instance</h1>
            </td>
        </tr>
        <tr>
            <td style="padding: 30px; background-color: #f9f9f9; border: 1px solid #ddd;">
                <p>Hello <strong>{{ object.partner_id.name }}</strong>,</p>

                <p>Great news! Your Odoo SaaS instance is now being provisioned.</p>

                <table style="width: 100%; margin: 20px 0; border-collapse: collapse;">
                    <tr>
                        <td style="padding: 8px; font-weight: bold; width: 40%;">Instance Name:</td>
                        <td style="padding: 8px;">{{ object.name }}</td>
                    </tr>
                    <tr style="background-color: #f0f0f0;">
                        <td style="padding: 8px; font-weight: bold;">Tenant ID:</td>
                        <td style="padding: 8px;">{{ object.tenant_id }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; font-weight: bold;">URL:</td>
                        <td style="padding: 8px;">
                            <a href="{{ object.url }}" style="color: #875A7B;">{{ object.url or 'Will be available shortly' }}</a>
                        </td>
                    </tr>
                    <tr style="background-color: #f0f0f0;">
                        <td style="padding: 8px; font-weight: bold;">Plan:</td>
                        <td style="padding: 8px;">{{ object.plan }}</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; font-weight: bold;">Status:</td>
                        <td style="padding: 8px;">
                            <span style="background-color: #f0ad4e; color: #fff; padding: 3px 10px; border-radius: 4px;">Provisioning</span>
                        </td>
                    </tr>
                </table>

                <p>Your instance will be ready within a few minutes. You will be able to access it at the URL above.</p>

                <p>If you have any questions, please don't hesitate to contact us.</p>

                <p>Best regards,<br/>
                <strong>AEI Software</strong></p>
            </td>
        </tr>
        <tr>
            <td style="background-color: #555; padding: 15px; color: #aaa; text-align: center; font-size: 12px; border-radius: 0 0 8px 8px;">
                This is an automated message from your SaaS management platform.
            </td>
        </tr>
    </table>
</div>
            </field>
        </record>

    </data>
</odoo>
