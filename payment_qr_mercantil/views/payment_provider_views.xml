<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend payment provider form to show QR Mercantil credentials -->
    <record id="payment_provider_form_qr_mercantil" model="ir.ui.view">
        <field name="name">payment.provider.form.qr_mercantil</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="QR Mercantil" invisible="code != 'qr_mercantil'">
                    <group string="Credenciales API">
                        <field name="qr_mercantil_base_url" string="URL Base API"/>
                        <field name="qr_mercantil_api_key" string="API Key (Login)" password="True"/>
                        <field name="qr_mercantil_api_key_service" string="API Key Servicio" password="True"/>
                        <field name="qr_mercantil_username" string="Usuario"/>
                        <field name="qr_mercantil_password" string="Contraseña" password="True"/>
                    </group>
                    <group string="Webhook (Callback)">
                        <field
                            name="qr_mercantil_webhook_url"
                            string="Webhook URL (Callback)"
                            placeholder="https://admin.aeisoftware.com/payment/qr_mercantil/webhook"
                        />
                        <div class="text-muted small ps-2">
                            Esta URL se env&#237;a al banco como campo <strong>callback</strong> en
                            cada solicitud de generaci&#243;n de QR. El banco la llamar&#225; cuando
                            el pago sea completado.<br/>
                            Si se deja en blanco se usa el dominio de
                            <code>web.base.url</code> + <code>/payment/qr_mercantil/webhook</code>.
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
